{
  "manifest_version": 3,
  "name": "Quran — Verse of the Day",
  "version": "1.0",
  "description": "A beautiful new tab page showing a different Quran verse every day.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": ["topSites"],
  "host_permissions": [
    "https://api.alquran.cloud/*",
    "https://api.quran.com/*",
    "https://api.aladhan.com/*",
    "https://geocoding-api.open-meteo.com/*"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}